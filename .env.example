ASSISTANT_NAME=Jarvis
OLLAMA_URL=http://localhost:11434
OLLAMA_MODELS=E:\.ollama\models
OLLAMA_LOAD_TIMEOUT=30m
OLLAMA_KEEP_ALIVE=30m
OLLAMA_CONTEXT_LENGTH=32768

# Lokaler Coding-Modus
OLLAMA_TEXT_MODEL=qwen3-coder-next:latest
OLLAMA_CODE_MODEL=qwen3-coder-next:latest
OLLAMA_MAX_CODE_MODEL=qwen3-coder-next:latest
OLLAMA_VISION_MODEL=llava:13b
OLLAMA_NUM_CTX=32768
OLLAMA_TEMPERATURE=0.03

PROJECT_DIR=Jarvis_Projects
MEMORY_DB=data/memory.sqlite
VOICE_RATE=165
VOICE_VOLUME=1.0
RECORD_SECONDS=5
VOSK_MODEL_DIR=models/vosk-model-small-de-0.15
BROWSER_USER_DATA=data/browser_profile


# Lokale KI-Bilder über Stable Diffusion WebUI API
IMAGE_API_URL=http://127.0.0.1:7860
IMAGE_MODEL_HINT=SDXL
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_STEPS=30
IMAGE_CFG_SCALE=7
IMAGE_SAMPLER=DPM++ 2M Karras
JARVIS_IMAGE_DEFAULT_2K=1
JARVIS_IMAGE_DEFAULT_4K=1
JARVIS_IMAGE_2K_SIZE=4096
JARVIS_IMAGE_TARGET_SIZE=4096

BEAST_MODE=1

# Best-Auto-Router
OLLAMA_AGENT_CODE_MODEL=qwen3-coder-next:latest
OLLAMA_STRONG_CODE_MODEL=qwen3-coder-next:latest
OLLAMA_BEAST_CODE_MODEL=qwen3-coder-next:latest
AUTO_BUILD_TEST=1
AUTO_FIX_ROUNDS=2
AUTO_GIT_SNAPSHOT=1
# RAG / Embeddings
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
RAG_DB=data/rag.sqlite
RAG_CHUNK_SIZE=1200
RAG_TOP_K=6
# Repo Agent
REPO_MAX_FILES=80
REPO_MAX_FILE_CHARS=12000
# Browser Agent V2
BROWSER_AGENT_MAX_STEPS=6
BROWSER_AGENT_BLOCK_SUBMIT=1
# ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DIR=external/ComfyUI
# Jarvis muss vor jedem ausführbaren Befehl genannt werden
REQUIRE_WAKE_WORD=1
WAKE_WORD=jarvis

# ULTRA Strongest settings
MULTI_AGENT_MODEL=qwen3-coder-next:latest
PLANNER_MODEL=qwen3-coder-next:latest
TESTER_MODEL=qwen3-coder-next:latest
FIXER_MODEL=qwen3-coder-next:latest
SECURITY_MODEL=qwen3-coder-next:latest
INTERNET_RESEARCH_MODEL=qwen3-coder-next:latest
PROJECT_MEMORY_DB=data/project_memory.sqlite
TASK_DB=data/tasks.sqlite
WEB_MEMORY_AUTO_INDEX=1
# ULTRA MAX modules
SOURCE_ARCHIVE_DB=data/source_archive.sqlite
HYBRID_RAG_KEYWORD_WEIGHT=0.35
HYBRID_RAG_VECTOR_WEIGHT=0.65
AUTOPILOT_MAX_STEPS=8
AUTOPILOT_BUILD_EVERY_STEP=1
STATUS_CHECK_TIMEOUT=8
TOOLCHAIN_CHECK_TIMEOUT=8
# Sandbox / Model Manager / Orange Core
SANDBOX_DIR=sandbox_runs
SANDBOX_TIMEOUT=180
SANDBOX_BLOCK_NETWORK=0
MODEL_MANAGER_PROFILE=ultra
ORANGE_CORE_ROTATION=1
# ProControl modules
CRASH_LOG_DIR=logs
CRASH_RESTART_DELAY=5
WINDOWS_AGENT_SCREENSHOT_DIR=data/screenshots
OCR_LANGUAGE=deu+eng
PROJECT_BACKUP_DIR=project_backups
AUTOPILOT_LOOP_MAX_ROUNDS=5
AUTOPILOT_LOOP_REQUIRE_TEST_PASS=1
VIDEO_OUTPUT_DIR=Jarvis_Projects/ki_videos
VIDEO_DEFAULT_SECONDS=4
